<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>QuizMaster - Interactive Quiz Platform</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary: #6366f1;
            --primary-dark: #4f46e5;
            --secondary: #ec4899;
            --success: #22c55e;
            --danger: #ef4444;
            --warning: #f59e0b;
            --bg: #0f172a;
            --surface: #1e293b;
            --surface-light: #334155;
            --text: #f8fafc;
            --text-muted: #94a3b8;
        }

        body {
            font-family: 'Segoe UI', system-ui, sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .container {
            width: 100%;
            max-width: 800px;
        }

        .card {
            background: var(--surface);
            border-radius: 20px;
            padding: 40px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            border: 1px solid var(--surface-light);
            animation: fadeIn 0.5s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        h1 {
            font-size: 2.5rem;
            margin-bottom: 10px;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-align: center;
        }

        .subtitle {
            text-align: center;
            color: var(--text-muted);
            margin-bottom: 30px;
        }

        .categories {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            margin-bottom: 30px;
        }

        .category-btn {
            background: var(--surface-light);
            border: 2px solid transparent;
            color: var(--text);
            padding: 20px;
            border-radius: 15px;
            cursor: pointer;
            font-size: 1.1rem;
            font-weight: 600;
            transition: all 0.3s ease;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
        }

        .category-btn:hover {
            border-color: var(--primary);
            transform: translateY(-3px);
            box-shadow: 0 10px 30px rgba(99, 102, 241, 0.2);
        }

        .category-btn .icon {
            font-size: 2rem;
        }

        .difficulty-selector {
            display: flex;
            gap: 10px;
            justify-content: center;
            margin-bottom: 30px;
        }

        .difficulty-btn {
            padding: 10px 25px;
            border-radius: 25px;
            border: 2px solid var(--surface-light);
            background: transparent;
            color: var(--text);
            cursor: pointer;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .difficulty-btn.active {
            background: var(--primary);
            border-color: var(--primary);
        }

        .difficulty-btn:hover:not(.active) {
            border-color: var(--primary);
        }

        .btn-primary {
            width: 100%;
            padding: 15px;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 1.1rem;
            font-weight: 600;
            cursor: pointer;
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(99, 102, 241, 0.3);
        }

        .btn-primary:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }

        /* Quiz Screen */
        .quiz-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            padding-bottom: 20px;
            border-bottom: 1px solid var(--surface-light);
        }

        .timer {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 1.2rem;
            font-weight: 600;
            color: var(--warning);
        }

        .timer.warning {
            color: var(--danger);
            animation: pulse 1s infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }

        .progress-bar {
            width: 100%;
            height: 8px;
            background: var(--surface-light);
            border-radius: 4px;
            margin-bottom: 30px;
            overflow: hidden;
        }

        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--primary), var(--secondary));
            border-radius: 4px;
            transition: width 0.3s ease;
        }

        .question {
            font-size: 1.3rem;
            font-weight: 600;
            margin-bottom: 25px;
            line-height: 1.5;
        }

        .options {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .option {
            background: var(--surface-light);
            border: 2px solid transparent;
            padding: 18px 20px;
            border-radius: 12px;
            cursor: pointer;
            font-size: 1rem;
            transition: all 0.2s;
            text-align: left;
            color: var(--text);
        }

        .option:hover:not(.disabled) {
            border-color: var(--primary);
            background: rgba(99, 102, 241, 0.1);
        }

        .option.correct {
            background: rgba(34, 197, 94, 0.2);
            border-color: var(--success);
            color: var(--success);
        }

        .option.wrong {
            background: rgba(239, 68, 68, 0.2);
            border-color: var(--danger);
            color: var(--danger);
        }

        .option.disabled {
            cursor: default;
            opacity: 0.7;
        }

        .explanation {
            margin-top: 20px;
            padding: 20px;
            background: rgba(99, 102, 241, 0.1);
            border-radius: 12px;
            border-left: 4px solid var(--primary);
            display: none;
        }

        .explanation.show {
            display: block;
            animation: fadeIn 0.3s ease;
        }

        .next-btn {
            margin-top: 20px;
            width: 100%;
            padding: 15px;
            background: var(--success);
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 1.1rem;
            font-weight: 600;
            cursor: pointer;
            display: none;
        }

        .next-btn.show {
            display: block;
            animation: fadeIn 0.3s ease;
        }

        /* Results Screen */
        .results-header {
            text-align: center;
            margin-bottom: 30px;
        }

        .score-circle {
            width: 150px;
            height: 150px;
            margin: 0 auto 20px;
            border-radius: 50%;
            background: conic-gradient(var(--primary) calc(var(--score) * 3.6deg), var(--surface-light) 0deg);
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }

        .score-circle::before {
            content: '';
            width: 120px;
            height: 120px;
            background: var(--surface);
            border-radius: 50%;
            position: absolute;
        }

        .score-text {
            position: relative;
            font-size: 2.5rem;
            font-weight: 700;
            z-index: 1;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 15px;
            margin-bottom: 30px;
        }

        .stat-box {
            background: var(--surface-light);
            padding: 20px;
            border-radius: 12px;
            text-align: center;
        }

        .stat-value {
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--primary);
        }

        .stat-label {
            color: var(--text-muted);
            font-size: 0.9rem;
            margin-top: 5px;
        }

        .review-section {
            margin-top: 30px;
        }

        .review-item {
            background: var(--surface-light);
            padding: 20px;
            border-radius: 12px;
            margin-bottom: 15px;
            border-left: 4px solid var(--danger);
        }

        .review-item.correct {
            border-left-color: var(--success);
        }

        .review-question {
            font-weight: 600;
            margin-bottom: 10px;
        }

        .review-answer {
            color: var(--text-muted);
            font-size: 0.95rem;
        }

        .review-answer .correct-ans {
            color: var(--success);
            font-weight: 600;
        }

        .review-answer .your-ans {
            color: var(--danger);
            font-weight: 600;
        }

        .hidden {
            display: none !important;
        }

        .fade-in {
            animation: fadeIn 0.5s ease;
        }

        /* Leaderboard */
        .leaderboard {
            margin-top: 20px;
        }

        .leaderboard-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px;
            background: var(--surface-light);
            border-radius: 10px;
            margin-bottom: 10px;
        }

        .leaderboard-rank {
            font-weight: 700;
            width: 30px;
        }

        .leaderboard-rank.gold { color: #ffd700; }
        .leaderboard-rank.silver { color: #c0c0c0; }
        .leaderboard-rank.bronze { color: #cd7f32; }

        @media (max-width: 600px) {
            .card { padding: 25px; }
            h1 { font-size: 1.8rem; }
            .categories { grid-template-columns: 1fr; }
            .stats-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Home Screen -->
        <div id="homeScreen" class="card">
            <h1>🧠 QuizMaster</h1>
            <p class="subtitle">Test your knowledge across various topics</p>
            
            <h3 style="margin-bottom: 15px; color: var(--text-muted);">Select Category</h3>
            <div class="categories">
                <button class="category-btn" onclick="selectCategory('general')">
                    <span class="icon">🌍</span>
                    <span>General Knowledge</span>
                </button>
                <button class="category-btn" onclick="selectCategory('science')">
                    <span class="icon">🔬</span>
                    <span>Science</span>
                </button>
                <button class="category-btn" onclick="selectCategory('history')">
                    <span class="icon">🏛️</span>
                    <span>History</span>
                </button>
                <button class="category-btn" onclick="selectCategory('tech')">
                    <span class="icon">💻</span>
                    <span>Technology</span>
                </button>
            </div>

            <h3 style="margin-bottom: 15px; color: var(--text-muted);">Select Difficulty</h3>
            <div class="difficulty-selector">
                <button class="difficulty-btn active" onclick="selectDifficulty('easy', this)">Easy</button>
                <button class="difficulty-btn" onclick="selectDifficulty('medium', this)">Medium</button>
                <button class="difficulty-btn" onclick="selectDifficulty('hard', this)">Hard</button>
            </div>

            <button class="btn-primary" id="startBtn" onclick="startQuiz()" disabled>Start Quiz</button>
        </div>

        <!-- Quiz Screen -->
        <div id="quizScreen" class="card hidden">
            <div class="quiz-header">
                <div>
                    <span id="categoryDisplay" style="color: var(--primary); font-weight: 600;"></span>
                    <span style="color: var(--text-muted);"> • Question <span id="currentQ">1</span>/<span id="totalQ">10</span></span>
                </div>
                <div class="timer" id="timer">
                    <span>⏱️</span>
                    <span id="timeLeft">30</span>s
                </div>
            </div>

            <div class="progress-bar">
                <div class="progress-fill" id="progressBar" style="width: 0%"></div>
            </div>

            <div class="question" id="questionText"></div>
            <div class="options" id="optionsContainer"></div>
            
            <div class="explanation" id="explanation">
                <strong>💡 Explanation:</strong>
                <p id="explanationText"></p>
            </div>
            
            <button class="next-btn" id="nextBtn" onclick="nextQuestion()">Next Question →</button>
        </div>

        <!-- Results Screen -->
        <div id="resultsScreen" class="card hidden">
            <div class="results-header">
                <h1>Quiz Complete! 🎉</h1>
                <div class="score-circle" id="scoreCircle">
                    <span class="score-text" id="scoreText">0%</span>
                </div>
                <p id="resultMessage" style="font-size: 1.2rem; margin-top: 10px;"></p>
            </div>

            <div class="stats-grid">
                <div class="stat-box">
                    <div class="stat-value" id="correctCount">0</div>
                    <div class="stat-label">Correct</div>
                </div>
                <div class="stat-box">
                    <div class="stat-value" id="wrongCount">0</div>
                    <div class="stat-label">Wrong</div>
                </div>
                <div class="stat-box">
                    <div class="stat-value" id="timeTaken">0s</div>
                    <div class="stat-label">Time Taken</div>
                </div>
            </div>

            <div class="review-section" id="reviewSection">
                <h3 style="margin-bottom: 15px;">Review Answers</h3>
                <div id="reviewContainer"></div>
            </div>

            <div style="display: flex; gap: 15px; margin-top: 30px;">
                <button class="btn-primary" onclick="restartQuiz()" style="flex: 1;">Try Again</button>
                <button class="btn-primary" onclick="goHome()" style="flex: 1; background: var(--surface-light);">New Quiz</button>
            </div>
        </div>
    </div>

